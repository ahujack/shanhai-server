# 后端环境变量配置

# Railway 会自动设置 DATABASE_URL

# JWT 密钥（生产环境请使用复杂的随机字符串）
JWT_SECRET=shanhai-jwt-secret-key-change-in-production-2024

# LLM API (用于 AI 对话和测字增强) - DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 邮件服务
RESEND_API_KEY=re_123456789

# 支付服务 - Creem (必须配置!)
# 请在 Railway 项目设置中添加此环境变量
# CREEM_API_KEY=your-creem-api-key-here

# Stripe 支付 (可选，目前主要使用 Creem)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# 允许的来源 (前端URL，逗号分隔)
ALLOWED_ORIGINS=https://shanhai-app.vercel.app,exp://*

# 前端 URL (用于支付回调)
FRONTEND_URL=https://shanhai-app.vercel.app

# 应用名称
APP_NAME=山海灵境

# 环境
NODE_ENV=production
