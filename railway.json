{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build",
    "startCommand": "node dist/main.js",
    "nixpacks": {
      "nodeVersion": "20"
    }
  },
  "deploy": {
  "numReplicas": 1,
  "restartPolicyType": "ON_FAILURE",
  "restartPolicyMaxRetries": 10,
  "preDeployCommand": "npx prisma generate && npx prisma migrate resolve --applied 20240308_add_referral_system || true && npx prisma migrate deploy"
  }
}
