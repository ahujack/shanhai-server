# 服务器配置
PORT=3000
NODE_ENV=development

# JWT 配置
# 生产环境请修改这个密钥！
JWT_SECRET=shanhai-secret-key-change-in-production

# 应用名称
APP_NAME=山海灵境

# ========== 邮件服务配置 (SMTP) ==========
# 请填入您的邮件服务器配置
# 示例使用 Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# 示例使用阿里云邮箱:
# SMTP_HOST=smtp.aliyun.com
# SMTP_PORT=465
# SMTP_USER=your-email@aliyun.com
# SMTP_PASS=your-password

# 测试环境可以留空，邮件会打印到控制台

# ========== 第三方登录配置 ==========
# Google 登录
# 1. 前往 https://console.cloud.google.com/
# 2. 创建项目并启用 Google+ API 或 Google Identity Services
# 3. 创建 OAuth 2.0 客户端 ID
# 4. 将客户端 ID 填入下方
GOOGLE_CLIENT_ID=

# Facebook 登录
# 1. 前往 https://developers.facebook.com/
# 2. 创建应用
# 3. 添加 Facebook 登录产品
# 4. 将 App ID 和 App Secret 填入下方
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ========== 短信服务配置 (可选) ==========
# 如果需要手机短信验证码，请配置
# ALIYUN_SMS_ACCESS_KEY_ID=
# ALIYUN_SMS_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=
