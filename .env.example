# Railway 会自动设置 DATABASE_URL
# 开发环境使用本地 PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/shanhai?schema=public"

# JWT 密钥（生产环境请使用复杂的随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# LLM API (用于 AI 对话和测字增强)
LLM_API_KEY="your_apiyi_api_key_here"
LLM_API_URL="https://api.apiyi.com/v1/chat/completions"
LLM_MODEL="gemini-1.5-flash-002"

# OCR API (手写识别)
OCR_API_KEY="your_apiyi_api_key_here"

# Google 登录
GOOGLE_CLIENT_ID="your_google_client_id"

# 邮件服务（可选，默认为模拟模式）
RESEND_API_KEY="your_resend_api_key"
