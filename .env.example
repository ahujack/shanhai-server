# Railway 会自动设置 DATABASE_URL
# 开发环境使用本地 PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/shanhai?schema=public"

# JWT 密钥（生产环境请使用复杂的随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# 多模态 (Gemini 等) — 测字识图、笔迹分析与识字共用同一套地址与 Key
LLM_API_KEY="your_gemini_api_key_here"
LLM_API_URL="https://api.apiyi.com/v1/chat/completions"
LLM_MODEL="gemini-2.5-flash"
# 可选：识字单独用更快/更便宜的模型（不填则用 LLM_MODEL）
# LLM_OCR_MODEL="gemini-2.0-flash"
# 可选：国内手写 OCR（有则优先，无则只用上面 LLM）
# BAIDU_OCR_API_KEY=
# BAIDU_OCR_SECRET_KEY=

# 纯文本 (DeepSeek) - 测字解读、八字解读、抽签、对话等
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
DEEPSEEK_API_URL="https://api.deepseek.com/chat/completions"
DEEPSEEK_MODEL="deepseek-chat"

# Google 登录
GOOGLE_CLIENT_ID="your_google_client_id"

# 邮件服务（可选，默认为模拟模式）
RESEND_API_KEY="your_resend_api_key"
