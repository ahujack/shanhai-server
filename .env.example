# Railway 会自动设置 DATABASE_URL
# 开发环境使用本地 PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/shanhai?schema=public"

# JWT 密钥（生产环境请使用复杂的随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# 多模态 (Gemini) - 手写识别等需要图片的
LLM_API_KEY="your_gemini_api_key_here"
LLM_API_URL="https://api.apiyi.com/v1/chat/completions"
LLM_MODEL="gemini-2.5-flash"

# 纯文本 (DeepSeek) - 测字解读、八字解读、抽签、对话等
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
DEEPSEEK_API_URL="https://api.deepseek.com/chat/completions"
DEEPSEEK_MODEL="deepseek-chat"

# Google 登录
GOOGLE_CLIENT_ID="your_google_client_id"

# 邮件服务（可选，默认为模拟模式）
RESEND_API_KEY="your_resend_api_key"
